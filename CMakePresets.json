{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 15,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-base",
            "displayName": "Windows (Ninja + Clang)",
            "hidden": true,
            "description": "Configure using Ninja generator and the Windows Clang toolchain from the cloned repo.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/Windows.Clang.toolchain.cmake",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "windows-debug",
            "displayName": "Windows Debug (Ninja + Clang)",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release (Ninja + Clang)",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "linux-base",
            "displayName": "Linux Clang",
            "hidden": true
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug (Clang)",
            "inherits": "linux-base",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release (Clang)",
            "inherits": "linux-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows",
            "displayName": "Build Debug (Clang)",
            "configurePreset": "windows-debug",
            "description": "Build using the ninja-clang configure preset."
        }
    ]
}